# ── Frontend environment variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Variables prefixed with VITE_ are exposed to the browser bundle.

# Full URL to your deployed Deno Deploy function.
# Shown in the Deno Deploy dashboard after creating the project.
# Format: https://<project-name>.deno.dev
VITE_COUNCIL_URL=https://model-council.deno.dev

# Optional: Bearer token for basic request authentication.
# If set, every request from the browser will include:
#   Authorization: Bearer <token>
# Add matching validation to the Edge Function if you enable this.
# VITE_API_AUTH_TOKEN=


# ── Deno Deploy secrets (server-side only) ────────────────────────────────
# These are NOT stored here. Set them via the Deno Deploy dashboard:
#   Project → Settings → Environment Variables → Add variable
#
# Or via the deployctl CLI:
#   deployctl projects env set ANTHROPIC_API_KEY=sk-ant-...  --project=model-council
#   deployctl projects env set OPENAI_API_KEY=sk-...         --project=model-council
#   deployctl projects env set GOOGLE_API_KEY=AIza...        --project=model-council
#
# Required:
#   ANTHROPIC_API_KEY   — from console.anthropic.com
#   OPENAI_API_KEY      — from platform.openai.com/api-keys
#   GOOGLE_API_KEY      — from aistudio.google.com/app/apikey
