# ── Frontend environment variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Variables prefixed with VITE_ are exposed to the browser.

# Full URL to the Supabase Edge Function.
# Find this in: Supabase dashboard → Edge Functions → council → Details
VITE_COUNCIL_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/council

# Your Supabase project's anon/public key (safe to expose in browser).
# Find this in: Supabase dashboard → Settings → API → Project API keys
VITE_SUPABASE_ANON_KEY=your-anon-key-here


# ── Supabase Edge Function secrets (server-side only) ────────────────────────
# These are NOT set in this file. Set them via the Supabase CLI:
#
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   supabase secrets set OPENAI_API_KEY=sk-...
#   supabase secrets set GOOGLE_API_KEY=AIza...
#
# Or via the Supabase dashboard → Edge Functions → Manage secrets.
# These values NEVER appear in the browser bundle.
