# ── Frontend environment variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Variables prefixed with VITE_ are exposed to the browser bundle.

# Where the frontend sends council requests.
#
# In production this is NOT needed: the site and API are served from the
# same origin, and the frontend defaults to the relative path /api/council.
#
# For local `npm run dev` you have two options:
#
#   Option A — use the deployed API (no local Deno needed):
#     VITE_COUNCIL_URL=https://model-council.sjm2669-stack.deno.net/api/council
#
#   Option B — run the API locally (leave VITE_COUNCIL_URL unset):
#     1. Export your API keys:  export ANTHROPIC_API_KEY=... OPENAI_API_KEY=... GOOGLE_API_KEY=...
#     2. Run the server:        deno task serve        (listens on :8000)
#     3. Run the frontend:      npm run dev            (vite proxies /api → :8000)
#
# VITE_COUNCIL_URL=

# Optional: Bearer token sent as "Authorization: Bearer <token>" on every
# council request. Add matching validation in server/council.ts if you use it.
# VITE_API_AUTH_TOKEN=


# ── Deno Deploy environment variables (server-side only) ────────────────────
# These are NOT stored here. Set them in the Deno Deploy dashboard:
#   Project → Settings → Environment Variables
#
# Required:
#   ANTHROPIC_API_KEY   — from console.anthropic.com
#   OPENAI_API_KEY      — from platform.openai.com/api-keys
#   GOOGLE_API_KEY      — from aistudio.google.com/app/apikey
